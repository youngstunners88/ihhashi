    "sqlite": {
      "name": "SQLite MCP",
      "description": "SQLite database operations",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sqlite", "/home/teacherchris37/data.db"]
    },
    "google-maps": {
      "name": "Google Maps MCP",
      "description": "Location & routing services",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-google-maps"],
      "env": {
        "GOOGLE_MAPS_API_KEY": "${GOOGLE_MAPS_API_KEY}"
      }
    },
    "google-calendar": {
      "name": "Google Calendar MCP",
      "description": "Calendar management",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-gcalendar"],
      "env": {
        "GOOGLE_CLIENT_ID": "${GOOGLE_CLIENT_ID}",
        "GOOGLE_CLIENT_SECRET": "${GOOGLE_CLIENT_SECRET}"
      }
    },
    "gmail": {
      "name": "Gmail MCP",
      "description": "Email automation",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-gmail"],
      "env": {
        "GMAIL_CREDENTIALS": "${GMAIL_CREDENTIALS}"
      }
    },
    "jupyter": {
      "name": "Jupyter MCP",
      "description": "Data science notebooks",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-jupyter"]
    },
    "qdrant": {
