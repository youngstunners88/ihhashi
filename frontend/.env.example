# =============================================================================
# iHhashi Frontend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Backend API Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# The base URL of the backend API server
# Development: http://localhost:8000
# Staging: https://staging-api.ihhashi.co.za
# Production: https://api.ihhashi.co.za (your Railway URL)
VITE_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Supabase Configuration (Authentication) - REQUIRED
# -----------------------------------------------------------------------------
# Get these from your Supabase project settings
# Project URL: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# -----------------------------------------------------------------------------
# PostHog Analytics (Optional)
# -----------------------------------------------------------------------------
# Analytics and feature flags
# Get your key from: https://app.posthog.com/project/settings
VITE_POSTHOG_KEY=your_posthog_key_here
VITE_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# Google Maps (Optional - for location features)
# -----------------------------------------------------------------------------
# Get API key from: https://console.cloud.google.com/apis/credentials
# Enable: Places API, Geocoding API, Maps JavaScript API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# -----------------------------------------------------------------------------
# Paystack (Payments)
# -----------------------------------------------------------------------------
# Get from: https://dashboard.paystack.com/#/settings/developer
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# -----------------------------------------------------------------------------
# GlitchTip/Sentry Error Tracking (Optional)
# -----------------------------------------------------------------------------
# Get from: https://app.glitchtip.com
VITE_SENTRY_DSN=https://your-dsn@app.glitchtip.com/project-id

# -----------------------------------------------------------------------------
# Feature Flags (Optional)
# -----------------------------------------------------------------------------
# Enable/disable features without code changes
VITE_ENABLE_CHATBOT=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_ANALYTICS=true

# -----------------------------------------------------------------------------
# App Configuration (Optional)
# -----------------------------------------------------------------------------
# Override app environment (defaults based on VITE_API_URL)
VITE_APP_ENV=development

# Currency symbol (default: R for South African Rand)
VITE_CURRENCY_SYMBOL=R

# Default language (default: en)
# Options: en, zu (Zulu), st (Sotho), af (Afrikaans), tn (Tswana), xh (Xhosa)
VITE_DEFAULT_LANGUAGE=en

# -----------------------------------------------------------------------------
# Build-time Variables (set during build, not runtime)
# -----------------------------------------------------------------------------
# These are baked into the build at compile time

# App version (usually set by CI/CD)
VITE_APP_VERSION=0.4.2
